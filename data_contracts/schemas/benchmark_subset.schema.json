{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prioritx.local/schemas/benchmark_subset.schema.json",
  "title": "PrioriTx Benchmark Subset",
  "type": "object",
  "required": [
    "schema_version",
    "subset_id",
    "benchmark_id",
    "mode",
    "objective",
    "readiness",
    "inclusion_principles",
    "included_datasets",
    "excluded_datasets",
    "notes"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "subset_id": { "type": "string" },
    "benchmark_id": { "type": "string" },
    "mode": {
      "type": "string",
      "enum": ["curated_prioritx_subset"]
    },
    "objective": { "type": "string" },
    "readiness": {
      "type": "string",
      "enum": ["candidate", "approved_for_first_wave"]
    },
    "inclusion_principles": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "included_datasets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "source",
          "selection_mode",
          "case_definition",
          "control_definition",
          "sample_counts",
          "reason"
        ],
        "properties": {
          "id": { "type": "string" },
          "source": { "type": "string" },
          "selection_mode": {
            "type": "string",
            "enum": ["direct", "requires_subsetting", "curated_public_arm"]
          },
          "case_definition": { "type": "string" },
          "control_definition": { "type": ["string", "null"] },
          "sample_counts": {
            "type": ["object", "null"],
            "properties": {
              "case": { "type": ["integer", "null"] },
              "control": { "type": ["integer", "null"] }
            },
            "additionalProperties": false
          },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "excluded_datasets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "reason"],
        "properties": {
          "id": { "type": "string" },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "notes": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
