{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prioritx.local/schemas/benchmark_target_assertion.schema.json",
  "title": "PrioriTx Benchmark Target Assertion",
  "type": "object",
  "required": [
    "schema_version",
    "assertion_status",
    "benchmark_id",
    "default_subset_id",
    "indication_name",
    "target_assertions",
    "notes"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "assertion_status": {
      "type": "string",
      "enum": ["source_backed"]
    },
    "benchmark_id": { "type": "string" },
    "default_subset_id": { "type": "string" },
    "exploratory_subset_id": { "type": ["string", "null"] },
    "indication_name": { "type": "string" },
    "recovery_tier": { "type": ["string", "null"] },
    "recovery_tier_note": { "type": ["string", "null"] },
    "target_assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "gene_symbol",
          "ensembl_gene_id",
          "label_tier",
          "assertion_kind",
          "source",
          "forbidden_feature_leakage"
        ],
        "properties": {
          "gene_symbol": { "type": "string" },
          "ensembl_gene_id": { "type": ["string", "null"] },
          "label_tier": {
            "type": "string",
            "enum": [
              "tier1_mechanistic_support",
              "tier2_translational_support",
              "tier3_programmatic_advancement"
            ]
          },
          "assertion_kind": {
            "type": "string",
            "enum": ["source_backed_positive_target"]
          },
          "source": {
            "type": "object",
            "required": ["title", "url", "note"],
            "properties": {
              "title": { "type": "string" },
              "url": { "type": "string" },
              "note": { "type": "string" }
            },
            "additionalProperties": false
          },
          "forbidden_feature_leakage": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "notes": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
