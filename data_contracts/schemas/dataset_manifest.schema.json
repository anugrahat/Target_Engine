{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prioritx.local/schemas/dataset_manifest.schema.json",
  "title": "PrioriTx Dataset Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "dataset_id",
    "benchmark_id",
    "accession",
    "source_publication_url",
    "disease_context",
    "modality",
    "tissue",
    "platform",
    "species",
    "role",
    "sample_units",
    "cohorts",
    "manifest_status",
    "provenance",
    "open_questions"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "dataset_id": { "type": "string" },
    "benchmark_id": { "type": "string" },
    "accession": {
      "type": "object",
      "required": ["database", "id", "url"],
      "properties": {
        "database": { "type": "string" },
        "id": { "type": "string" },
        "url": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "source_publication_url": { "type": "string" },
    "disease_context": {
      "type": "object",
      "required": ["name", "ontology_ids"],
      "properties": {
        "name": { "type": "string" },
        "ontology_ids": {
          "type": "object",
          "additionalProperties": { "type": ["string", "null"] }
        }
      },
      "additionalProperties": false
    },
    "modality": { "type": "string" },
    "tissue": { "type": ["string", "null"] },
    "platform": { "type": ["string", "null"] },
    "species": { "type": "string" },
    "role": { "type": "string" },
    "sample_units": {
      "type": "string",
      "enum": [
        "bulk_sample",
        "single_cell_sample",
        "subject_level_summary",
        "supplementary_summary"
      ]
    },
    "cohorts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "cohort_id",
          "label",
          "case_control_status",
          "disease_subtype",
          "sample_count",
          "status",
          "notes"
        ],
        "properties": {
          "cohort_id": { "type": "string" },
          "label": { "type": "string" },
          "case_control_status": {
            "type": "string",
            "enum": ["case", "control", "mixed", "unknown"]
          },
          "disease_subtype": { "type": ["string", "null"] },
          "sample_count": { "type": ["integer", "null"] },
          "status": {
            "type": "string",
            "enum": ["verified", "partial"]
          },
          "notes": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "manifest_status": {
      "type": "string",
      "enum": ["verified", "partial"]
    },
    "provenance": {
      "type": "object",
      "required": ["primary_source_url", "extraction_method", "extracted_from_section"],
      "properties": {
        "primary_source_url": { "type": "string" },
        "extraction_method": { "type": "string" },
        "extracted_from_section": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
